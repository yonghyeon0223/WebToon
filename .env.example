# Required ──────────────────────────────────────────────────────
# Google Gemini API key (https://aistudio.google.com/)
GEMINI_API_KEY=

# Optional (defaults shown) ─────────────────────────────────────
# Gemini image generation model. Verify availability in AI Studio
# and override if a newer/more-capable model is available.
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Concurrency cap for parallel Gemini API calls within a stage.
MAX_PARALLEL_REQUESTS=5

# Per-call timeout for image generation (ms).
GENERATION_TIMEOUT_MS=120000

# Retry attempts on failed generation (excludes the initial attempt).
MAX_RETRIES=3

# Storage backend. Currently only 'local'. ('r2' will be added later.)
STORAGE_BACKEND=local

# Logging verbosity: error | warn | info | debug
LOG_LEVEL=info

# Absolute path to the directory containing the `passages/` folder.
# Defaults to process.cwd() when unset.
WORKSPACE_ROOT=

# development | production | test
NODE_ENV=development
