{
  "name": "webtoon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Personal pipeline for converting Korean SAT mock-exam English passages into Mr. Men style picture books via Gemini Pro.",
  "engines": {
    "node": ">=24.11.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm run type-check && npm run test"
  },
  "dependencies": {
    "pino": "9.6.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "@vitest/coverage-v8": "2.1.8",
    "eslint": "9.18.0",
    "eslint-config-prettier": "9.1.0",
    "pino-pretty": "13.0.0",
    "prettier": "3.4.2",
    "typescript": "5.7.3",
    "typescript-eslint": "8.20.0",
    "vitest": "2.1.8"
  }
}
